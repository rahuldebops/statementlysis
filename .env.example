# Database
DB_TYPE=local  # 'local' or 'neon'

# Local Database
LOCAL_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ledgerlense
LOCAL_DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/ledgerlense

# Neon Database (Remote)
NEON_DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.aws.neon.tech/neondb?ssl=true
NEON_DATABASE_URL_SYNC=postgresql+psycopg2://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require

DB_SCHEMA=public

# Storage
PDF_STORAGE_PATH=./storage/pdfs

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# Security
SECRET_KEY=change-me-in-production

# Google Drive Archival
GOOGLE_DRIVE_CREDENTIALS_PATH=./secrets/ledgerlense.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=

