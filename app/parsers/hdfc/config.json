{
    "bank_id": "hdfc",
    "version": "1.0.0",
    "headers": ["Date", "Narration", "Chq./Ref.No.", "Value Dt", "Withdrawal Amt.", "Deposit Amt.", "Closing Balance"],
    "date_patterns": [
        "\\d{2}/\\d{2}/\\d{2,4}",
        "\\d{2}-\\d{2}-\\d{2,4}"
    ],
    "amount_patterns": [
        "\\d{1,3}(?:,\\d{2,3})*\\.\\d{2}"
    ],
    "ignore_patterns": [
        "^\\s*Page\\s+\\d+",
        "^\\s*HDFC\\s*BANK",
        "^\\s*Statement\\s+of\\s+Account",
        "^\\s*Account\\s+No",
        "^\\s*Account\\s+Branch",
        "^\\s*RTGS",
        "^\\s*NEFT",
        "^\\s*$"
    ],
    "header_keywords": ["Date", "Narration", "Chq", "Ref", "Value", "Withdrawal", "Deposit", "Closing", "Balance"],
    "footer_keywords": ["Statement Summary", "Total", "OPENING BALANCE", "CLOSING BALANCE"],
    "multiline_narration": true,
    "columns": [
        {"name": "date", "x_start": 20, "x_end": 85, "required": true},
        {"name": "narration", "x_start": 85, "x_end": 340, "required": true},
        {"name": "chq_ref", "x_start": 340, "x_end": 420, "required": false},
        {"name": "value_date", "x_start": 420, "x_end": 490, "required": false},
        {"name": "withdrawal", "x_start": 490, "x_end": 570, "required": false},
        {"name": "deposit", "x_start": 570, "x_end": 650, "required": false},
        {"name": "balance", "x_start": 650, "x_end": 750, "required": false}
    ],
    "extra": {
        "common_formats": ["savings_standard", "savings_detailed"],
        "notes": "HDFC statements have relatively consistent column layouts across savings and current accounts"
    }
}
