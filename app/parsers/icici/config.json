{
    "bank_id": "icici",
    "version": "1.0.0",
    "headers": ["S No.", "Value Date", "Transaction Date", "Cheque Number", "Transaction Remarks", "Withdrawal Amount (INR )", "Deposit Amount (INR )", "Balance (INR )"],
    "date_patterns": ["\\d{2}/\\d{2}/\\d{4}", "\\d{2}-\\d{2}-\\d{4}"],
    "amount_patterns": ["\\d{1,3}(?:,\\d{2,3})*\\.\\d{2}"],
    "ignore_patterns": ["^\\s*Page\\s+\\d+", "^\\s*ICICI", "^\\s*Account\\s+Statement", "^\\s*$"],
    "header_keywords": ["Date", "Transaction", "Remarks", "Withdrawal", "Deposit", "Balance"],
    "footer_keywords": ["Total", "Closing Balance"],
    "multiline_narration": true,
    "columns": [
        {"name": "sno", "x_start": 15, "x_end": 45, "required": false},
        {"name": "value_date", "x_start": 45, "x_end": 110, "required": false},
        {"name": "txn_date", "x_start": 110, "x_end": 175, "required": true},
        {"name": "chq_no", "x_start": 175, "x_end": 240, "required": false},
        {"name": "remarks", "x_start": 240, "x_end": 430, "required": true},
        {"name": "withdrawal", "x_start": 430, "x_end": 520, "required": false},
        {"name": "deposit", "x_start": 520, "x_end": 610, "required": false},
        {"name": "balance", "x_start": 610, "x_end": 720, "required": false}
    ]
}
