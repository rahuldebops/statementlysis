{
    "bank_id": "generic",
    "version": "1.0.0",
    "headers": ["Date", "Narration", "Description", "Particulars", "Debit", "Credit", "Balance", "Amount"],
    "date_patterns": [
        "\\d{2}[/\\-]\\d{2}[/\\-]\\d{2,4}",
        "\\d{2}\\s+\\w{3}\\s+\\d{2,4}",
        "\\d{2}/\\d{2}/\\d{4}"
    ],
    "amount_patterns": [
        "\\d{1,3}(?:,\\d{2,3})*\\.\\d{2}",
        "\\d+\\.\\d{2}"
    ],
    "ignore_patterns": [
        "^\\s*Page\\s+\\d+",
        "^\\s*Statement\\s+of\\s+Account",
        "^\\s*Opening\\s+Balance",
        "^\\s*Closing\\s+Balance",
        "^\\s*Total\\s*$",
        "^\\s*$"
    ],
    "header_keywords": ["Date", "Narration", "Chq", "Debit", "Credit", "Balance"],
    "footer_keywords": ["Total", "Closing Balance", "Statement Summary"],
    "multiline_narration": true,
    "columns": [],
    "extra": {
        "note": "Generic parser uses heuristic column detection since column positions vary by bank"
    }
}
